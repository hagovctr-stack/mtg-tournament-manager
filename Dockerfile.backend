FROM node:20-alpine
WORKDIR /app

# Copy package files
COPY backend/package.json ./
RUN npm install

# Copy prisma schema
COPY database/schema.prisma ./prisma/schema.prisma
RUN npx prisma generate

# Copy source and build
COPY backend/ ./
RUN npm run build

EXPOSE 3001
CMD npx prisma migrate deploy && node dist/server.js
