    Standing {
        string id PK
        string tournamentId FK
        string tournamentPlayerId FK
        int matchPoints
        int matchWins
        int matchLosses
        int matchDraws
        int gameWins
        int gameLosses
        int gameDraws
        float omwPercent
        float gwPercent
        float ogwPercent
        int rank
        datetime updatedAt
    }

    Tournament ||--o{ TournamentPlayer : "players"
    Tournament ||--o{ Round : "rounds"
    Tournament ||--o{ Standing : "standings"
    Player ||--o{ TournamentPlayer : "linked profile"
    Round ||--o{ Match : "matches"
    TournamentPlayer ||--o{ Match : "as player1"
