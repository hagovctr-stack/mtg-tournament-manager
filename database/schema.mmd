erDiagram
    Tournament {
        string id PK
        string name
        string format
        string bestOfFormat
        string status
        int totalRounds
        int currentRound
        datetime createdAt
        datetime updatedAt
    }

    Player {
        string id PK
        string name
        string normalizedName
        string dciNumber UK
        int rating
        datetime createdAt
        datetime updatedAt
    }

    TournamentPlayer {
        string id PK
        string tournamentId FK
